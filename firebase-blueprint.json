{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A construction or design project featuring artificial stone work.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the project" },
        "title": {
          "type": "object",
          "properties": {
            "sr": { "type": "string" },
            "en": { "type": "string" }
          },
          "required": ["sr", "en"]
        },
        "description": {
          "type": "object",
          "properties": {
            "sr": { "type": "string" },
            "en": { "type": "string" }
          },
          "required": ["sr", "en"]
        },
        "category": { "type": "string", "enum": ["enterijer", "eksterijer"] },
        "subcategory": {
          "type": "object",
          "properties": {
            "sr": { "type": "string" },
            "en": { "type": "string" }
          },
          "required": ["sr", "en"]
        },
        "imageUrl": { "type": "string", "format": "uri" },
        "gallery": {
          "type": "array",
          "items": { "type": "string", "format": "uri" }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "category", "subcategory", "imageUrl", "gallery"]
    },
    "SiteSettings": {
      "title": "SiteSettings",
      "description": "Global configuration for the website.",
      "type": "object",
      "properties": {
        "featuresImageUrl": { "type": "string", "description": "Image for the features section on home page." },
        "aboutImageUrl": { "type": "string", "description": "Image for the about page." },
        "logoImageUrl": { "type": "string", "description": "Optional logo image URL. If empty, text logo is used." }
      }
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of all projects"
    },
    "/site_settings/{id}": {
      "schema": "SiteSettings",
      "description": "Global website settings and images."
    }
  }
}
