rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: projects
    // Document ID: auto-generated or project ID
    // Fields:
    //   - title: map (sr: string, en: string)
    //   - description: map (sr: string, en: string)
    //   - category: string (enterijer/eksterijer)
    //   - subcategory: map (sr: string, en: string)
    //   - imageUrl: string (URL)
    //   - gallery: list (URLs)
    //   - createdAt: timestamp
    //   - updatedAt: timestamp
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "nemanjamilin.contact@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidProject(data) {
      return data.keys().hasAll(['title', 'description', 'category', 'subcategory', 'imageUrl', 'gallery']) &&
             data.title.sr is string && data.title.en is string &&
             data.description.sr is string && data.description.en is string &&
             data.category in ['enterijer', 'eksterijer'] &&
             data.subcategory.sr is string && data.subcategory.en is string &&
             data.imageUrl is string &&
             data.gallery is list;
    }

    match /projects/{projectId} {
      allow read, write: if true;
    }

    match /site_settings/{id} {
      allow read, write: if true;
    }
  }
}
